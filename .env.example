# Tenderly — dashboard.tenderly.co → Node → copy key after last slash of HTTPS URL
TENDERLY_NODE_ACCESS_KEY=

# x402 payment (your Base wallet address to receive payments)
WALLET_ADDRESS=
PRICE_PER_REQUEST=0.01
# base-sepolia for testing, base for production
PAYMENT_NETWORK=base-sepolia
PAYMENT_FACILITATOR_URL=

# Optional live USD pricing. If omitted or unavailable, PreFlight uses fallback estimates.
COINGECKO_API_KEY=

# Server
PORT=3000
NODE_ENV=development

# Paid smoke tests and Claude MCP bridge only.
# Use a funded test wallet, never a main wallet.
PAYER_PRIVATE_KEY=
PREFLIGHT_URL=http://localhost:3000

# Optional Sepolia demo payload
TEST_TX_FROM=0x1ad4C9d7CEa32B44cd54260A52C57B6Ce4e0D6eB
TEST_TX_TO=0x8E159C52Dc2823cB6728E26898A2bABC286BBAc7
TEST_TX_DATA=0x
TEST_TX_VALUE=1000000000000000
TEST_TX_CHAIN_ID=11155111
